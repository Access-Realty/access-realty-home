# Supabase - same instance as access-realty-app
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
# Secret key for server-side operations (bypasses RLS)
# Use per-repo named keys from Supabase Dashboard > API Keys > Secret keys
# Production: access_realty_home_secret (sb_secret_sPC7P...)
# Staging: sb_secret_vz3Gt...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx

# Google Analytics (optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe - must match same account as access-realty-app (account 51SNJmU)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx  # Client-side (for EmbeddedCheckout)
STRIPE_SECRET_KEY=sk_test_xxxx                    # Server-side (for session creation)
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Price IDs from Stripe dashboard
STRIPE_PRICE_DIRECT_LIST=price_xxxx               # $495 DirectList upfront
STRIPE_PRICE_DIRECT_LIST_PLUS=price_xxxx           # $995 DirectList+ upfront
STRIPE_PRICE_INVESTOR_1995=price_xxxx              # $1,995 Investor tier upfront

# Calendly - for scheduling
CALENDLY_API_TOKEN=xxxx
CALENDLY_WEBHOOK_SECRET=xxxx
# Inquiries event type for solutions pages (15 min consultation)
NEXT_PUBLIC_CALENDLY_INQUIRIES_URI=https://api.calendly.com/event_types/xxxx

# Google Maps - same key as access-realty-app (shared across repos)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapbox — for interactive maps on SEO property pages
# Public token (domain-restricted in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.xxxx

# URLs
NEXT_PUBLIC_SITE_URL=https://access.realty
NEXT_PUBLIC_APP_URL=https://access.realty/app

# PromoteKit (affiliate marketing)
NEXT_PUBLIC_PROMOTEKIT_ID=                         # From PromoteKit dashboard → Settings → Script
NEXT_PUBLIC_PROMOTEKIT_SIGNUP_URL=                 # PromoteKit affiliate signup portal URL

# Sentry (create a new project at sentry.io for this repo)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
